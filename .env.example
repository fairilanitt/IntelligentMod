# =============================================================
#  IntelligentMod — Environment Variables
#  Copy this file to .env and fill in your values.
# =============================================================

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Application (client) ID — found on the "General Information" page
CLIENT_ID=

# (Optional) A single guild ID for faster slash-command registration
# during development.  Leave blank for global (production) registration.
GUILD_ID=

# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
